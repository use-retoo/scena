,349,352,358],{},[285,350,351],{},"Control buttons",[285,353,354,294,356],{},[291,355,293],{},[291,357,297],{},[285,359,360],{},"Activate (play, pause, mute, close, CTA)",[252,362,363,364,367,368,371],{},"The seek step is a fraction of the video duration, ",[291,365,366],{},"0.05"," (5%) by default. Configure it via the ",[291,369,370],{},"step"," prop of the progress component:",[373,374,379],"pre",{"className":375,"code":376,"language":377,"meta":378,"style":378},"language-ts shiki shiki-themes material-theme-lighter material-theme material-theme-palenight","const scena = useScena({\n  config: {\n    videoProgress: {\n      step: 0.1 // seek 10% per keypress\n    }\n  }\n});\n","ts","",[291,380,381,408,421,431,447,453,459],{"__ignoreMap":378},[382,383,386,390,394,398,402,405],"span",{"class":384,"line":385},"line",1,[382,387,389],{"class":388},"spNyl","const",[382,391,393],{"class":392},"sTEyZ"," scena ",[382,395,397],{"class":396},"sMK4o","=",[382,399,401],{"class":400},"s2Zo4"," useScena",[382,403,404],{"class":392},"(",[382,406,407],{"class":396},"{\n",[382,409,411,415,418],{"class":384,"line":410},2,[382,412,414],{"class":413},"swJcz","  config",[382,416,417],{"class":396},":",[382,419,420],{"class":396}," {\n",[382,422,424,427,429],{"class":384,"line":423},3,[382,425,426],{"class":413},"    videoProgress",[382,428,417],{"class":396},[382,430,420],{"class":396},[382,432,434,437,439,443],{"class":384,"line":433},4,[382,435,436],{"class":413},"      step",[382,438,417],{"class":396},[382,440,442],{"class":441},"sbssI"," 0.1",[382,444,446],{"class":445},"sHwdD"," // seek 10% per keypress\n",[382,448,450],{"class":384,"line":449},5,[382,451,452],{"class":396},"    }\n",[382,454,456],{"class":384,"line":455},6,[382,457,458],{"class":396},"  }\n",[382,460,462,465,468],{"class":384,"line":461},7,[382,463,464],{"class":396},"}",[382,466,467],{"class":392},")",[382,469,470],{"class":396},";\n",[252,472,473,474,477],{},"Video controls and volume buttons appear on ",[291,475,476],{},":focus-within"," as well as on hover, so keyboard users always see which control is focused.",[256,479,481],{"id":480},"focus-management","Focus management",[252,483,484,485,489],{},"In ",[486,487,488],"a",{"href":95},"preview mode"," the collapsed widget acts as a single button: the container is the only tab stop and its inner controls are skipped, so keyboard users don't tab through invisible elements.",[252,491,492],{},"When the widget expands, focus moves to the first available control — progress bar, then play/pause, then volume — depending on which components are enabled. When it collapses while focus is inside, focus returns to the container instead of being lost to the page.",[256,494,496],{"id":495},"screen-readers","Screen readers",[252,498,499,500,503,504,507,508,511,512,515,516,519,520,523,524,527],{},"The container exposes ",[291,501,502],{},"role=\"button\"",", and the progress bar exposes ",[291,505,506],{},"role=\"slider\""," with ",[291,509,510],{},"aria-valuemin",", ",[291,513,514],{},"aria-valuemax",", and ",[291,517,518],{},"aria-valuenow",". The current position is announced as human-readable time via ",[291,521,522],{},"aria-valuetext"," — for example ",[291,525,526],{},"1:25 / 3:40"," — instead of raw percentages.",[252,529,530,531,534],{},"Every interactive component accepts an ",[291,532,533],{},"aria"," prop to override or extend its attributes:",[373,536,538],{"className":375,"code":537,"language":377,"meta":378,"style":378},"const scena = useScena({\n  config: {\n    videoContainer: {\n      aria: {\n        ariaLabel: 'Watch product demo'\n      }\n    },\n    videoControls: {\n      aria: {\n        play: { ariaLabel: 'Play demo video' },\n        pause: { ariaLabel: 'Pause demo video' }\n      }\n    }\n  }\n});\n",[291,539,540,554,562,571,580,597,602,607,617,626,653,677,682,687,692],{"__ignoreMap":378},[382,541,542,544,546,548,550,552],{"class":384,"line":385},[382,543,389],{"class":388},[382,545,393],{"class":392},[382,