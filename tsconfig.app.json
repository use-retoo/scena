{
	"extends": "@tsconfig/svelte/tsconfig.json",

	"compilerOptions": {
		/* Build optimization */
		"tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
		"target": "ES2022",
		"module": "ESNext",
		"types": ["svelte", "vite/client"],
		"allowImportingTsExtensions": true,
		"useDefineForClassFields": true,
		"noEmit": true,

		/* JavaScript support */
		"allowJs": true,
		"checkJs": true,

		/* Module resolution */
		"moduleDetection": "force",
		"paths": { "@/*": ["./src/*"] }
	},

	/* Source files */
	"include": [
		"src/**/*.ts",
		"src/**/*.js",
		"src/**/*.svelte",
		"playground/**/*.ts",
		"playground/**/*.js",
		"playground/**/*.svelte"
	]
}
