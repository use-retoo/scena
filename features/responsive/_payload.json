ayer below ",[256,538,539],{},"preview"," — so preview always takes priority.",[521,542,543],{},"When no breakpoint matches, all responsive overrides are cleared and the base config is restored.",[265,545,547],{"id":546},"breakpoint-priority","Breakpoint priority",[252,549,550],{},"Override layers are applied in fixed order:",[306,552,557],{"className":553,"code":555,"language":556},[554],"language-text","base config → responsive → preview\n","text",[256,558,555],{"__ignoreMap":311},[252,560,561],{},"Preview always wins — if preview is active, its overrides take precedence over the matched breakpoint.",[265,563,565],{"id":564},"runtime-api","Runtime API",[252,567,568,569,304],{},"The responsive API is available at ",[256,570,571],{},"instance.responsive",[573,574,575,591],"table",{},[576,577,578],"thead",{},[579,580,581,585,588],"tr",{},[582,583,584],"th",{},"Property",[582,586,587],{},"Type",[582,589,590],{},"Description",[592,593,594],"tbody",{},[579,595,596,602,607],{},[597,598,599],"td",{},[256,600,601],{},"activeBreakpoint",[597,603,604],{},[256,605,606],{},"number | null",[597,608,609,610,613],{},"The currently matched breakpoint in px, or ",[256,611,612],{},"null"," if none matched",[306,615,617],{"className":308,"code":616,"language":310,"meta":311,"style":311},"console.log(instance.responsive.activeBreakpoint);\n",[256,618,619],{"__ignoreMap":311},[315,620,621,624,626,629,632,634,636,638,641],{"class":317,"line":318},[315,622,623],{"class":325},"console",[315,625,330],{"class":329},[315,627,628],{"class":333},"log",[315,630,631],{"class":325},"(instance",[315,633,330],{"class":329},[315,635,258],{"class":325},[315,637,330],{"class":329},[315,639,640],{"class":325},"activeBreakpoint)",[315,642,501],{"class":329},[644,645,646],"style",{},"html pre.shiki code .s7zQu, html code.shiki .s7zQu{--shiki-light:#39ADB5;--shiki-light-font-style:italic;--shiki-default:#89DDFF;--shiki-default-font-style:italic;--shiki-dark:#89DDFF;--shiki-dark-font-style:italic}html pre.