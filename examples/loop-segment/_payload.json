   loop: false,\n      muted: true,\n    },\n    size: ComponentSize.MD,\n    shape: ComponentShape.CIRCLE,\n    container: {\n      position: ComponentPosition.ABSOLUTE,\n      placement: ComponentPlacement.MIDDLE_CENTER,\n    },\n    ctaButton: false,\n    closeButton: false,\n  },\n  document.getElementById('target'),\n);\n\ninstance.api.events.on(ScenaEvent.ON_VIDEO_TIME_UPDATE, () => {\n  const { currentTime } = instance.api.controller;\n\n  if (currentTime >= SEGMENT_END) {\n    instance.api.controller.seek(SEGMENT_START);\n  }\n});\n","main.ts","ts","",[248,282,283,296,306,314,322,330,338,346,368,375,389,394,413,428,433,452,457,482,488,500,517,530,544,557,563,581,599,609,627,645,650,662,674,680,706,713,718,758,790,795,818,846,852],{"__ignoreMap":280},[284,285,288,292],"span",{"class":286,"line":287},"line",1,[284,289,291],{"class":290},"s7zQu","import",[284,293,295],{"class":294},"sMK4o"," {\n",[284,297,299,303],{"class":286,"line":298},2,[284,300,302],{"class":301},"sTEyZ","  useScena",[284,304,305],{"class":294},",\n",[284,307,309,312],{"class":286,"line":308},3,[284,310,311],{"class":301},"  ScenaEvent",[284,313,305],{"class":294},[284,315,317,320],{"class":286,"line":316},4,[284,318,319],{"class":301},"  ComponentSize",[284,321,305],{"class":294},[284,323,325,328],{"class":286,"line":324},5,[284,326,327],{"class":301},"  ComponentShape",[284,329,305],{"class":294},[284,331,333,336],{"class":286,"line":332},6,[284,334,335],{"class":301},"  ComponentPosition",[284,337,305],{"class":294},[284,339,341,344],{"class":286,"line":340},7,[284,342,343],{"class":301},"  ComponentPlacement",[284,345,305],{"class":294},[284,347,349,352,355,358,362,365],{"class":286,"line":348},8,[284,350,351],{"class":294},"}",[284,353,354],{"class":290}," from",[284,356,357],{"class":294}," '",[284,359,361],{"class":360},"sfazB","@retoo/scena",[284,363,364],{"class":294},"'",[284,366,367],{"class":294},";\n",[284,369,371],{"class":286,"line":370},9,[284,372,374],{"emptyLinePlaceholde